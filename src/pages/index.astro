---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Avatar from '@/components/Avatar.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';

const proyectos = await getCollection('proyectos');
const projects = proyectos
  .sort((a, b) => (b.data.year || '').localeCompare(a.data.year || ''));
---

<Base title="Allison Peña — Desarrollador web full stack">
  <Navbar />

  <main class="max-w-[58ch] mx-auto px-6 md:px-8 pt-4 pb-16 md:pb-24">

    <section class="min-h-[45vh] mt-20 md:mt-28 mb-28 md:mb-36">
      <h2 class="hero-heading font-display text-5xl md:text-6xl xl:text-7xl leading-[1.05] font-normal tracking-tight">
        Interfaces que se olvidan <span class="text-muted">de existir.</span>
      </h2>
      <p class="hero-subtitle font-mono text-base md:text-lg leading-[1.6] text-muted mt-6">
        Me interesa cómo el código se vuelve invisible. Cómo lo que construyes importa más que cómo lo construyes.
      </p>
    </section>

    <section id="proyectos" class="mb-32 md:mb-40 scroll-mt-20">
      <ul class="space-y-12">
        {projects.map((p) => (
          <li>
            <a
              href={`/proyectos/${p.id}`}
              class="group py-3"
            >
              <h2 class="font-display text-3xl md:text-4xl leading-[1.1] tracking-tight group-hover:opacity-70 transition-opacity duration-200 mb-2">
                {p.data.title}
              </h2>
              <p class="font-sans text-base leading-[1.7] text-muted">
                {p.data.description}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section id="sobre-mi" class="mb-32 md:mb-40 scroll-mt-20">
      <div class="flex flex-col gap-8 items-start">
        <Avatar id="about-avatar" className="w-[140px] h-[140px] md:w-[160px] md:h-[160px] rounded-full border border-border" />
        <div class="space-y-6">
          <p class="font-sans text-lg leading-[1.8]">
            Me interesa cómo las interfaces se vuelven invisibles. Que la tecnología importe menos que lo que permite hacer.
          </p>
          <p class="font-sans text-base leading-[1.8] text-muted">
            Trabajo principalmente con React, Astro y herramientas que priorizan rendimiento y accesibilidad. Prefiero resolver problemas con menos código que más.
          </p>
        </div>
      </div>
    </section>

    <Footer />

  </main>
</Base>
