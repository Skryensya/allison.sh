---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';

const proyectos = await getCollection('proyectos');
const projects = proyectos
  .sort((a, b) => (b.data.year || '').localeCompare(a.data.year || ''));
---

<Base title="Allison Peña — Desarrollador web full stack">
  <header id="site-header" class="w-full sticky top-0 z-50 transition-all duration-300">
    <nav id="site-nav" class="max-w-[58ch] mx-auto px-4 md:px-8 flex justify-between items-center py-4 md:py-8 transition-all duration-300 bg-bg md:bg-transparent">
      <h1 class="font-sans text-xl font-medium tracking-tight"><span class="font-light">Allison</span> Peña</h1>
      <div class="flex items-center gap-6">
        <a href="#proyectos" class="font-mono text-sm tracking-wide transition-colors duration-200 text-muted hover:text-text">work</a>
        <button
          id="theme-toggle"
          class="font-mono text-sm tracking-wide transition-colors duration-200 text-muted hover:text-text"
        >
          <span class="dark:hidden">dark</span>
          <span class="hidden dark:inline">light</span>
        </button>
      </div>
    </nav>
  </header>

  <main class="max-w-[58ch] mx-auto px-6 md:px-8 pt-4 pb-16 md:pb-24">

    <section class="min-h-[70vh] mt-24 md:mt-32 mb-32 md:mb-40">
      <h2 class="hero-heading font-sans text-5xl md:text-6xl xl:text-7xl leading-[1.05] font-light tracking-tight">
        Me gusta construir <span class="text-muted">para la web.</span>
      </h2>
      <p class="hero-subtitle font-mono text-base md:text-lg leading-[1.6] text-muted mt-6">
        Full-stack developer. Diseño y desarrollo experiencias web accesibles, mantenibles y con intención.
      </p>
    </section>

    <section id="proyectos" class="mb-32 md:mb-40 scroll-mt-20">
      <p class="font-mono text-xs tracking-[0.2em] uppercase mb-10 text-subtle">Proyectos</p>
      <ul class="space-y-8">
        {projects.map((p) => (
          <li>
            <a
              href={`/proyectos/${p.id}`}
              class="group py-3"
            >
              <div class="flex items-baseline gap-3 mb-1">
                <span class="font-sans text-2xl md:text-3xl leading-[1.1] tracking-tight group-hover:text-muted transition-colors duration-200">
                  {p.data.title}
                </span>
                <span class="font-mono text-[11px] text-subtle">{p.data.year}</span>
              </div>
              <p class="font-sans text-base text-muted leading-[1.6] group-hover:text-text transition-colors duration-200">
                {p.data.description}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mb-32 md:mb-40">
      <p class="font-mono text-xs tracking-[0.2em] uppercase mb-8 text-subtle">Contacto</p>
      <ul class="space-y-3">
        <li>
          <a href="https://github.com/Skryensya" class="font-sans text-sm transition-colors duration-200 hover:text-muted">
            GitHub
          </a>
        </li>
        <li>
          <a href="https://linkedin.com/in/skryensya" class="font-sans text-sm transition-colors duration-200 hover:text-muted">
            LinkedIn
          </a>
        </li>
        <li>
          <a href="mailto:contacto@allison.sh" class="font-sans text-sm transition-colors duration-200 hover:text-muted">
            Email
          </a>
        </li>
      </ul>
    </section>

    <footer class="font-mono text-xs tracking-wide text-subtle">
      <div class="flex justify-between items-center">
        <p>© 2026 Allison Peña</p>
        <nav class="flex gap-5">
          <a href="/curriculum.pdf" class="transition-colors duration-200 hover:text-muted">CV</a>
        </nav>
      </div>
    </footer>

  </main>
</Base>
