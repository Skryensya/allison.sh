---
import Base from '@/layouts/Base.astro';
---

<Base title="404 — Página no encontrada">
  <header id="site-header" class="w-full sticky top-0 z-50 transition-all duration-300 overflow-hidden">
    <nav id="site-nav" class="max-w-[58ch] mx-auto px-6 md:px-8 flex justify-between items-center py-4 md:py-8 transition-all duration-300">
      <h1 class="font-display text-xl font-medium tracking-tight shrink-0"><a href="/" class="hover:text-muted transition-colors duration-200"><span class="font-light">Allison</span> Peña</a></h1>
    </nav>
  </header>

  <main class="max-w-[58ch] mx-auto px-6 md:px-8 pt-4">
    <section class="min-h-[60vh] flex flex-col justify-center">
      <p class="font-mono text-sm tracking-wide text-muted mb-4">404</p>
      <h2 class="font-display text-5xl md:text-6xl xl:text-7xl leading-[1.05] font-normal tracking-tight mb-8">
        Nada aquí.
      </h2>
      <p class="font-mono text-base leading-[1.7] text-muted max-w-[40ch]">
        La página que buscas no existe, o quizás nunca existió. El link puede estar roto o mal escrito.
      </p>
      <a 
        href="/" 
        class="inline-block mt-12 font-sans text-base transition-colors duration-200 hover:text-muted group"
      >
        <span class="mr-2 text-muted group-hover:text-text transition-colors duration-200">←</span>
        <span class="border-b border-current pb-0.5">Volver al inicio</span>
      </a>
    </section>
  </main>
</Base>
