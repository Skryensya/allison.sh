---
interface Props {
  showBack?: boolean;
}

const { showBack = false } = Astro.props;
---

<header id="site-header" class="w-full sticky top-0 z-[200]">
  <nav id="site-nav" class="max-w-[58ch] mx-auto px-6 md:px-8 flex justify-between items-center py-4 md:py-8">
    <h1 id="nav-logo" class="font-display text-xl font-medium tracking-tight shrink-0 -ml-2">
      <a href="/" class="hover:text-muted transition-colors duration-200"><span class="font-light">Allison</span> Peña</a>
    </h1>
    <div id="nav-links" class="flex items-center gap-3 md:gap-6 flex-wrap justify-end">
      <a href="#proyectos" class="font-sans text-sm tracking-wide transition-colors duration-200 text-muted hover:text-text">work</a>
      <a href="#sobre-mi" class="font-sans text-sm tracking-wide transition-colors duration-200 text-muted hover:text-text">about</a>
      <a href="#contacto" class="font-sans text-sm tracking-wide transition-colors duration-200 text-muted hover:text-text">contact</a>
      <button
        id="theme-toggle"
        class="font-sans text-sm tracking-wide transition-colors duration-200 text-muted hover:text-text"
      >
        <span class="dark-label">dark</span>
        <span class="light-label" style="display:none">light</span>
      </button>
    </div>
  </nav>
</header>
