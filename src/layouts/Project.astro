---
import Base from './Base.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import TableOfContents from '@/components/TableOfContents.astro';

interface Props {
  title: string;
  description: string;
  year?: string;
}

const { title, description, year } = Astro.props;
---

<Base title={`${title} | Allison Peña`} description={description}>
  <Navbar showBack={true} />

  <main class="max-w-[58ch] mx-auto px-6 md:px-8 pt-4 pb-16 md:pb-24">

    <section class="mt-16 md:mt-20 mb-10 md:mb-12">
      <h1 class="font-display text-3xl md:text-4xl leading-[1.12] mb-3 tracking-tight">
        {title}
      </h1>
      {year && (
        <span class="font-sans text-xs text-subtle">{year}</span>
      )}
    </section>

    <article class="font-mono text-base leading-[1.85] text-text tracking-tight">
      <slot />
    </article>

    <style>
      article :global(h2) {
        font-family: var(--font-sans);
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        color: var(--color-muted);
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
      }
    </style>

    <footer class="mt-12 md:mt-14">
      <a href="/" class="inline-flex items-center gap-1.5 font-mono text-[11px] tracking-wide transition-colors duration-200 text-muted hover:text-text group">
        <svg class="w-3 h-3 transition-transform duration-200 group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        volver
      </a>
    </footer>

    <Footer />

  </main>

  <TableOfContents />
</Base>
