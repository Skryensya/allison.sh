---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description || 'Allison Peña — Desarrollador web full stack'} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content="#f4f1eb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f0f0e" media="(prefers-color-scheme: dark)" />
    <!-- Preconnect to fontshare CDN for faster font loading -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="dns-prefetch" href="https://api.fontshare.com" />
    <!-- Critical CSS: inline for fast first paint and zero CLS -->
    <style>:root{--font-display:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;--font-mono:ui-monospace,"SF Mono",Menlo,Monaco,monospace;--font-sans:var(--font-display);--color-bg:#f4f1eb;--color-text:#1f1c18;--color-muted:#4a4742;--color-border:#c8c3ba;--theme-colorful:#f4f1eb;--theme-contrasty:#3d3832}*,::before,::after{box-sizing:border-box;margin:0;padding:0}@font-face{font-family:"system-ui";font-display:block;src:local("system-ui")}body{background-color:var(--color-bg);color:var(--color-text);font-family:var(--font-sans);line-height:1.5;min-height:100vh;-webkit-font-smoothing:antialiased}h1,h2{font-family:var(--font-display);line-height:1.05;font-weight:400;letter-spacing:-0.025em}.hero-heading{font-size:clamp(2.5rem,5vw,5.5rem);line-height:1.05}.font-display{font-family:var(--font-display)}.font-mono{font-family:var(--font-mono)}.font-sans{font-family:var(--font-sans)}.text-muted{color:var(--color-muted)}.text-text{color:var(--color-text)}.antialiased{-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}img,video,svg{vertical-align:middle;max-width:100%;height:auto}.avatar{--avatar-black:var(--theme-contrasty);--avatar-white:var(--theme-colorful);--avatar-gray:color-mix(in srgb,var(--theme-colorful) 82%,var(--theme-contrasty) 18%);contain:layout paint style;content-visibility:auto;contain-intrinsic-size:150px 150px;display:block;position:relative;width:100%;height:100%}.avatar__button{display:flex;align-items:center;justify-content:center;border:0;padding:0;background:var(--theme-colorful);overflow:hidden;width:100%;height:100%;cursor:pointer}.avatar__grid{position:absolute;display:grid;gap:0;top:-8px;left:50%;transform:translateX(-50%)}.avatar__tile{width:32px;height:32px;display:block;user-select:none;pointer-events:none;shape-rendering:crispEdges}.avatar svg{image-rendering:pixelated;image-rendering:crisp-edges}</style>
    <Font cssVariable="--font-display" />
    <ClientRouter />
  </head>
  <body class="text-text antialiased min-h-screen bg-bg relative">
    <!-- Skip to main content link for keyboard users -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:bg-bg focus:text-text focus:px-4 focus:py-2 focus:outline-none focus:ring-2 focus:ring-border">
      Saltar al contenido principal
    </a>
    <!-- Noise texture overlay -->
    <div class="pointer-events-none fixed inset-0 z-[60] opacity-[0.035] dark:opacity-[0.04]" style="background-image: url('data:image/svg+xml,<svg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22><filter id=%22noise%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/></svg>'); background-repeat: repeat; background-size: 256px 256px;"></div>
    <!-- Luz tenue desde arriba a la derecha -->
    <div id="light-overlay" class="pointer-events-none fixed inset-0 z-50" style="background: radial-gradient(ellipse 100vw 100vh at 100% 0%, oklab(0.92 0.05 0.08 / 0.45), transparent 60%);"></div>
    <!-- Fade en la parte superior -->
    <div id="top-fade" class="pointer-events-none fixed top-0 left-0 right-0 z-30 transition-all duration-300" style="height: 0px; background: linear-gradient(to bottom, var(--color-bg) 0%, transparent 80%); -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 80%); mask-image: linear-gradient(to bottom, black 0%, transparent 80%);"></div>
    <div id="bottom-fade" class="pointer-events-none fixed bottom-0 left-0 right-0 z-30 transition-all duration-300" style="height: 0px; background: linear-gradient(to top, var(--color-bg) 0%, transparent 80%); -webkit-mask-image: linear-gradient(to top, black 0%, transparent 80%); mask-image: linear-gradient(to top, black 0%, transparent 80%);"></div>
    <div class="min-h-[100dvh]">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  html {
    --avatar-black: var(--theme-contrasty);
    --avatar-white: var(--theme-colorful);
    --avatar-gray: color-mix(in srgb, var(--theme-colorful) 82%, var(--theme-contrasty) 18%);
    --avatar-colorful-50: color-mix(in srgb, var(--theme-colorful) 25%, var(--theme-contrasty) 75%);
  }

  html.dark {
    --color-bg: #0F0F0E;
    --color-text: #E0DDD8;
    --color-muted: #9B9590;
    --color-subtle: #858280;
    --color-border: #4A4740;
    --color-link: #FF6030;
    /* Avatar keeps light theme colors */
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-12px);
    }
  }

  ::view-transition-old(root) {
    animation: fade-out 0.15s ease-out forwards;
  }

  ::view-transition-new(root) {
    animation: fade-in 0.2s ease-out forwards;
  }

@media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none;
    }
  }
</style>

<script is:inline>
(function(){function applyTheme(){var saved=localStorage.getItem('theme');var prefersDark=window.matchMedia('(prefers-color-scheme: dark)').matches;document.documentElement.classList.toggle('dark',saved==='dark'||(!saved&&prefersDark));}function updateToggleText(){var toggle=document.getElementById('theme-toggle');if(!toggle)return;var isDark=document.documentElement.classList.contains('dark');toggle.setAttribute('aria-label',isDark?'Cambiar a modo claro':'Cambiar a modo oscuro');var darkSpan=toggle.querySelector('.dark-label');var lightSpan=toggle.querySelector('.light-label');if(darkSpan&&lightSpan){darkSpan.style.display=isDark?'inline':'none';lightSpan.style.display=isDark?'none':'inline';}}function restoreScrollPosition(){var state=history.state;window.scrollTo(0,state?.scrollY??0);}function initLightOverlay(){var overlay=document.getElementById('light-overlay');if(!overlay)return;function update(){overlay.style.opacity='0.4';}window.addEventListener('scroll',update,{passive:true});update();}function initTopFade(){var fade=document.getElementById('top-fade');if(!fade)return;var lastScrollY=window.scrollY;function update(){var scrollY=window.scrollY;fade.style.height=Math.min(scrollY,200)+'px';lastScrollY=scrollY;}window.addEventListener('scroll',update,{passive:true});update();}function initBottomFade(){var fade=document.getElementById('bottom-fade');if(!fade)return;function update(){fade.style.height=Math.min(window.scrollY*0.5,200)+'px';}window.addEventListener('scroll',update,{passive:true});update();}function initNavbarScroll(){var header=document.getElementById('site-header');var logo=document.getElementById('nav-logo');var links=document.getElementById('nav-links');if(!header||!logo||!links)return;var overlay=document.createElement('div');overlay.id='header-click-blocker';overlay.style.cssText='position:fixed;top:0;left:0;right:0;height:0;z-index:99;pointer-events:none;transition:height 0.25s ease-out;';document.body.appendChild(overlay);var lastScrollY=0,isHidden=false,rafId=null;var threshold=20;function animate(){var scrollY=window.scrollY;var shouldHide=scrollY>threshold&&scrollY>lastScrollY&&scrollY>0;var isBase=scrollY<=threshold;if(shouldHide&&!isHidden){logo.style.transform='translateX(-130%)';logo.style.transition='transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';links.style.transform='translateX(120%)';links.style.transition='transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';setTimeout(function(){overlay.style.height=header.offsetHeight+'px';overlay.style.pointerEvents='auto';},50);isHidden=true;}else if(isHidden&&isBase){overlay.style.pointerEvents='none';overlay.style.height='0px';logo.style.transform='translateX(0)';logo.style.transition='transform 0.15s cubic-bezier(0.2, 0, 0, 1)';links.style.transform='translateX(0)';links.style.transition='transform 0.15s cubic-bezier(0.2, 0, 0, 1)';isHidden=false;}lastScrollY=scrollY;}window.addEventListener('scroll',function(){if(rafId)cancelAnimationFrame(rafId);rafId=requestAnimationFrame(animate);},{passive:true});}function initGlitch(){var wrapper=document.querySelector('.name-wrapper');var glitchChars=document.querySelectorAll('.glitch-char');if(!wrapper||!glitchChars.length)return;var sequence=['/','-','\\','|','/'];var tid=null;var anim=false;function cycle(){if(anim)return;anim=true;var i=0,c=0;function nxt(){glitchChars.forEach(function(ch){ch.textContent=sequence[i];});i=(i+1)%sequence.length;if(i===0){c++;if(c>=5){tid=null;anim=false;glitchChars.forEach(function(ch){ch.textContent=ch.getAttribute('data-char')||'/';});return;}}tid=setTimeout(nxt,120);}nxt();}wrapper.addEventListener('mouseenter',function(){if(tid)clearTimeout(tid);anim=false;setTimeout(cycle,250);});wrapper.addEventListener('mouseleave',function(){if(tid)clearTimeout(tid);tid=null;anim=false;glitchChars.forEach(function(ch){ch.textContent=ch.getAttribute('data-char')||'/';});});}function init(){applyTheme();updateToggleText();restoreScrollPosition();initLightOverlay();initTopFade();initBottomFade();initNavbarScroll();initGlitch();document.getElementById('theme-toggle')?.addEventListener('click',function(){var isDark=document.documentElement.classList.toggle('dark');localStorage.setItem('theme',isDark?'dark':'light');updateToggleText();});}init();document.addEventListener('astro:after-swap',init);})();
</script>
