---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description || 'Allison Peña — Desarrollador web full stack'} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <Font cssVariable="--font-display" />
    <ClientRouter />
  </head>
  <body class="text-text antialiased min-h-screen bg-bg relative">
    <!-- Noise texture overlay -->
    <div class="pointer-events-none fixed inset-0 z-[60] opacity-[0.035] dark:opacity-[0.04]" style="background-image: url('data:image/svg+xml,<svg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22><filter id=%22noise%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/></svg>'); background-repeat: repeat; background-size: 256px 256px;"></div>
    <!-- Luz tenue desde arriba a la derecha -->
    <div id="light-overlay" class="pointer-events-none fixed inset-0 z-50" style="background: radial-gradient(ellipse 100vw 100vh at 100% 0%, oklab(0.92 0.05 0.08 / 0.45), transparent 60%);"></div>
    <!-- Fade en la parte superior -->
    <div id="top-fade" class="pointer-events-none fixed top-0 left-0 right-0 z-30 transition-all duration-300" style="height: 0px; background: linear-gradient(to bottom, var(--color-bg) 0%, transparent 80%); -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 80%); mask-image: linear-gradient(to bottom, black 0%, transparent 80%);"></div>
    <div id="bottom-fade" class="pointer-events-none fixed bottom-0 left-0 right-0 z-30 transition-all duration-300" style="height: 0px; background: linear-gradient(to top, var(--color-bg) 0%, transparent 80%); -webkit-mask-image: linear-gradient(to top, black 0%, transparent 80%); mask-image: linear-gradient(to top, black 0%, transparent 80%);"></div>
    <div class="min-h-[100dvh]">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  html {
    --avatar-black: var(--theme-contrasty);
    --avatar-white: var(--theme-colorful);
    --avatar-gray: color-mix(in srgb, var(--theme-colorful) 82%, var(--theme-contrasty) 18%);
    --avatar-colorful-50: color-mix(in srgb, var(--theme-colorful) 25%, var(--theme-contrasty) 75%);
  }

  html.dark {
    --color-bg: #0F0F0E;
    --color-text: #E0DDD8;
    --color-muted: #9B9590;
    --color-subtle: #858280;
    --color-border: #4A4740;
    --color-link: #FF6030;
    /* Avatar keeps light theme colors */
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-12px);
    }
  }

  ::view-transition-old(root) {
    animation: fade-out 0.15s ease-out forwards;
  }

  ::view-transition-new(root) {
    animation: fade-in 0.2s ease-out forwards;
  }

@media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none;
    }
  }
</style>

<script>
  function applyTheme() {
    const saved = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (saved === 'dark' || (!saved && prefersDark)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }

  function updateToggleText() {
    const toggle = document.getElementById('theme-toggle');
    if (!toggle) return;
    const isDark = document.documentElement.classList.contains('dark');
    const darkSpan = toggle.querySelector('.dark-label');
    const lightSpan = toggle.querySelector('.light-label');
    if (darkSpan && lightSpan) {
      darkSpan.style.display = isDark ? 'inline' : 'none';
      lightSpan.style.display = isDark ? 'none' : 'inline';
    }
  }

  function restoreScrollPosition() {
    const state = history.state;
    if (state && state.scrollY !== undefined) {
      window.scrollTo(0, state.scrollY);
    } else {
      window.scrollTo(0, 0);
    }
  }

  function initThemeToggle() {
    applyTheme();
    updateToggleText();
    const toggle = document.getElementById('theme-toggle');
    toggle?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateToggleText();
    });
  }

  initThemeToggle();
  restoreScrollPosition();

  document.addEventListener('astro:after-swap', () => {
    initThemeToggle();
    restoreScrollPosition();
    initLightOverlay();
    initNavbarScroll();
  });

  // Animar overlay de luz con scroll
  function initLightOverlay() {
    const overlay = document.getElementById('light-overlay');
    if (!overlay) return;

    function updateLight(e) {
      const scrollY = window.scrollY;
      const maxScroll = window.innerHeight * 0.7;
      const progress = Math.min(scrollY / maxScroll, 1);
      const opacity = 0.4;
      overlay.style.opacity = opacity;
    }

    window.addEventListener('scroll', updateLight, { passive: true });
    updateLight();
  }

  initLightOverlay();

  // Fade de contenido con scroll
  function initTopFade() {
    const fade = document.getElementById('top-fade');
    if (!fade) return;

    let lastScrollY = window.scrollY;
    const maxFade = 200; // altura máxima del fade en px

    function updateFade() {
      const scrollY = window.scrollY;
      const scrollingUp = scrollY < lastScrollY;
      
      // Crecer el fade cuando scrollea hacia arriba, achicarlo hacia abajo
      const height = Math.min(scrollY, maxFade);
      fade.style.height = `${height}px`;
      
      lastScrollY = scrollY;
    }

    window.addEventListener('scroll', updateFade, { passive: true });
    updateFade();
  }

  initTopFade();
  document.addEventListener('astro:after-swap', initTopFade);

  // Fade de contenido en el bottom con scroll
  function initBottomFade() {
    const fade = document.getElementById('bottom-fade');
    if (!fade) return;

    const maxFade = 200; // altura máxima del fade en px

    function updateFade() {
      const scrollY = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      
      // Fade aparece cuando scrolleaseas
      const height = Math.min(scrollY * 0.5, maxFade);
      fade.style.height = `${height}px`;
    }

    window.addEventListener('scroll', updateFade, { passive: true });
    updateFade();
  }

  initBottomFade();
  document.addEventListener('astro:after-swap', initBottomFade);

  // Navbar scroll animation - elements slide out with easing
  function initNavbarScroll() {
    const logo = document.getElementById('nav-logo');
    const links = document.getElementById('nav-links');
    
    if (!logo || !links) return;

    let lastScrollY = window.scrollY;
    let isHidden = false;
    let rafId = null;
    const threshold = 20;

    function animateNavbar() {
      const currentScrollY = window.scrollY;
      const scrollingDown = currentScrollY > lastScrollY;
      const shouldHide = currentScrollY > threshold && scrollingDown && currentScrollY > 0;

      if (shouldHide && !isHidden) {
        // Slide out - faster on way down
        logo.style.transform = 'translateX(-120%)';
        logo.style.transition = 'transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';
        
        links.style.transform = 'translateX(120%)';
        links.style.transition = 'transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';
        
        isHidden = true;
      } else if (isHidden && currentScrollY === 0) {
        // Only show when at the very top
        logo.style.transform = 'translateX(0)';
        logo.style.transition = 'transform 0.15s cubic-bezier(0.2, 0, 0, 1)';
        
        links.style.transform = 'translateX(0)';
        links.style.transition = 'transform 0.15s cubic-bezier(0.2, 0, 0, 1)';
        
        isHidden = false;
      }

      lastScrollY = currentScrollY;
    }

    function onScroll() {
      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(animateNavbar);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  }

  initNavbarScroll();
  document.addEventListener('astro:after-swap', initNavbarScroll);
</script>
